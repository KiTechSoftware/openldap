###########################
# LDAP Server Configuration
###########################
LDAP_ORGANISATION="Example Corp"
LDAP_DOMAIN="example.com"
LDAP_BASE_DN="dc=example,dc=com"

# Default admin (root) user for LDAP
LDAP_ADMIN_DN="cn=admin,dc=example,dc=com"
LDAP_ADMIN_PASSWORD="SuperSecretPassword123!"

# Additional read-only or service account
LDAP_READONLY_USER=true
LDAP_READONLY_USER_USERNAME="readonly"
LDAP_READONLY_USER_PASSWORD="ReadOnlyPass123!"

###########################
# TLS / SSL Configuration
###########################
LDAP_ENABLE_TLS=true
LDAP_TLS_CRT_FILENAME=ldap.crt
LDAP_TLS_KEY_FILENAME=ldap.key
LDAP_TLS_CA_CRT_FILENAME=ca.crt
LDAP_TLS_VERIFY_CLIENT=try   # Options: never | allow | try | demand

###########################
# Networking & Service
###########################
LDAP_URI="ldap://0.0.0.0:389 ldaps://0.0.0.0:636"
LDAP_PORT=389
LDAP_SSL_PORT=636

# Restrict which IP addresses the server listens to
SLAPD_LISTEN_URIS="ldap:/// ldaps:///"

###########################
# Logging / Debugging
###########################
SLAPD_DEBUG_LEVEL=0        # -1 for verbose
LDAP_LOG_LEVEL=256         # Adjust for syslog

###########################
# Data Initialization
###########################
LDAP_CONFIG_PASSWORD="ConfigSecret!"
LDAP_REMOVE_CONFIG_AFTER_SETUP=false
LDAP_SEED_LDIF_PATH=/container/service/slapd/assets/config/bootstrap/ldif/custom

###########################
# Optional: Replication (if using multiple LDAP nodes)
###########################
LDAP_REPLICATION=false
LDAP_REPLICATION_HOSTS="ldap://ldap1.example.com ldap://ldap2.example.com"
LDAP_REPLICATION_USER_DN="cn=replicator,dc=example,dc=com"
LDAP_REPLICATION_PASSWORD="ReplicationPass123!"

###########################
# Default OpenLDAP Environment Variables (Server)
###########################
LDAP_USER=openldap
LDAP_GROUP=openldap
LDAP_SERVICES="ldap:/// ldapi:///"
LDAP_OPTIONS=""
LDAP_CONF_DIR=/etc/ldap/slapd.d

###########################
# Default OpenLDAP Environment Variables (Client)
###########################
LDAPCONF= #(file path)	Path to the global or user config file. Overrides the default /etc/ldap/ldap.conf.
LDAPRC= #(file path)	Path to the user’s rc file (~/.ldaprc). Overrides the default.
LDAPNOINIT= #(boolean)	If set (to any value), disables reading any config files (ldap.conf, ldaprc).
LDAPURI= #(URI)	Specifies one or more LDAP server URIs, e.g. ldap://localhost:389.
LDAPBASE= #(BASE)	Default base Distinguished Name (DN) for searches.
LDAPBINDDN= #(BINDDN)	Default DN to bind as.
LDAPBINDPW= #(none)	Password for the bind DN — usually discouraged in plain text.
LDAPSASL_MECH= #(SASL_MECH)	SASL mechanism to use (e.g. GSSAPI, DIGEST-MD5).
LDAPSASL_REALM= #(SASL_REALM)	SASL realm parameter.
LDAPSASL_AUTHCID= #(SASL_AUTHCID)	Authentication identity (username).
LDAPSASL_AUTHZID= #(SASL_AUTHZID)	Authorization identity.
LDAPSASL_SECPROPS= #(SASL_SECPROPS)	SASL security properties string.
LDAPREFERRALS= #(REFERRALS)	Whether to automatically follow referrals (on/off).
LDAPTLS_CACERT= #(TLS_CACERT)	Path to a trusted CA certificate file.
LDAPTLS_CACERTDIR= #(TLS_CACERTDIR)	Directory containing CA certs.
LDAPTLS_CERT= #(TLS_CERT)	Path to client certificate.
LDAPTLS_KEY= #(TLS_KEY)	Path to client private key.
LDAPTLS_CIPHER_SUITE= #(TLS_CIPHER_SUITE)	List of allowed TLS cipher suites.
LDAPTLS_PROTOCOL_MIN= #(TLS_PROTOCOL_MIN)	Minimum allowed TLS protocol version (e.g. 3.1 for TLS 1.0).
LDAPTLS_RAND= #(TLS_RAND)	Path to a file with random data for seeding the TLS RNG.
LDAPTLS_REQCERT= #(TLS_REQCERT)	Server certificate verification policy: never, allow, try, demand.
LDAPSTARTTLS= #(STARTTLS)	Whether to issue a StartTLS operation before binding (yes/no/try).
LDAPDEBUG= #(none)		Sets the debug level for client library (same as -d flag).